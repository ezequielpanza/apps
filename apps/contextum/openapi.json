{
  "openapi": "3.1.0",
  "info": {
    "title": "Contextum GPT Action API",
    "version": "0.3.1",
    "description": "Read-only access to a temporary Contextum context snapshot using an 8-character code generated by the user in Contextum."
  },
  "servers": [
    {
      "url": "https://contextum.pages.dev"
    }
  ],
  "paths": {
    "/api/action/context/{code}": {
      "get": {
        "operationId": "getContextByCode",
        "summary": "Get a temporary Contextum context snapshot",
        "description": "Use only when the user provides a current 8-character Contextum code. This operation is read-only. Codes expire after 10 minutes.",
        "parameters": [
          {
            "name": "code",
            "in": "path",
            "required": true,
            "description": "8-character temporary Contextum code provided by the user.",
            "schema": {
              "type": "string",
              "pattern": "^[A-HJ-NP-Z2-9]{8}$",
              "minLength": 8,
              "maxLength": 8
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Current temporary read-only Contextum snapshot.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ContextResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid code format."
          },
          "404": {
            "description": "Code expired, unknown, or context unavailable."
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ContextResponse": {
        "type": "object",
        "properties": {
          "source": {
            "type": "string",
            "const": "contextum"
          },
          "access": {
            "type": "string",
            "const": "temporary-read-only"
          },
          "context": {
            "$ref": "#/components/schemas/ContextSnapshot"
          }
        },
        "required": ["source", "access", "context"]
      },
      "ContextSnapshot": {
        "type": "object",
        "properties": {
          "schemaVersion": { "type": "integer" },
          "appVersion": { "type": ["string", "null"] },
          "capturedAt": { "type": "string" },
          "receivedAt": { "type": "string" },
          "location": {
            "oneOf": [
              { "$ref": "#/components/schemas/Location" },
              { "type": "null" }
            ]
          },
          "context": {
            "type": "object",
            "properties": {
              "activeNote": { "type": ["string", "null"] }
            }
          },
          "runtime": {
            "type": "object",
            "properties": {
              "visible": { "type": "boolean" },
              "focused": { "type": "boolean" },
              "companionMode": { "type": "boolean" }
            }
          }
        }
      },
      "Location": {
        "type": "object",
        "properties": {
          "latitude": { "type": "number", "minimum": -90, "maximum": 90 },
          "longitude": { "type": "number", "minimum": -180, "maximum": 180 },
          "accuracyM": { "type": ["number", "null"] },
          "speedKmh": { "type": ["number", "null"] },
          "headingDeg": { "type": ["number", "null"] },
          "altitudeM": { "type": ["number", "null"] },
          "timestamp": { "type": ["string", "null"] }
        },
        "required": ["latitude", "longitude"]
      }
    }
  }
}
