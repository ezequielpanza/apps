function normalizeHeading(deg) {
  const value = Number(deg);
  if (!Number.isFinite(value)) return null;
  return ((value % 360) + 360) % 360;
}

function bearingBetween([lat1, lng1], [lat2, lng2]) {
  const toRad = (value) => (value * Math.PI) / 180;
  const toDeg = (value) => (value * 180) / Math.PI;
  const phi1 = toRad(lat1);
  const phi2 = toRad(lat2);
  const lambda = toRad(lng2 - lng1);
  const y = Math.sin(lambda) * Math.cos(phi2);
  const x = Math.cos(phi1) * Math.sin(phi2) - Math.sin(phi1) * Math.cos(phi2) * Math.cos(lambda);
  return normalizeHeading(toDeg(Math.atan2(y, x)));
}

function offsetFromHeading([lat, lng], headingDeg, meters) {
  const heading = normalizeHeading(headingDeg);
  if (!Number.isFinite(heading)) return [lat, lng];
  const latDelta = meters / 111320;
  const lngDelta = meters / (111320 * Math.cos((lat * Math.PI) / 180));
  const rad = (heading * Math.PI) / 180;
  const northSouth = Math.cos(rad);
  const eastWest = Math.sin(rad);
  return [lat + latDelta * northSouth, lng + lngDelta * eastWest];
}

function currentNavigationMode() {
  return navigationModes[navigationModeIndex];
}

function focusTargetForCurrentMode(current) {
  const mode = currentNavigationMode().id;
  if (mode === "north") return current;
  if (mode === "movement" && Number.isFinite(lastMovementBearing)) {
    return offsetFromHeading(current, lastMovementBearing, 170);
  }
  if (mode === "compass") {
    if (Number.isFinite(compassHeading)) return offsetFromHeading(current, compassHeading, 170);
    if (Number.isFinite(lastMovementBearing)) return offsetFromHeading(current, lastMovementBearing, 170);
  }
  return current;
}

function withProgrammaticMapMove(action) {
  programmaticMapMoveCount += 1;
  try {
    action();
    map.once("moveend", () => {
      programmaticMapMoveCount = Math.max(0, programmaticMapMoveCount - 1);
    });
  } catch (error) {
    programmaticMapMoveCount = Math.max(0, programmaticMapMoveCount - 1);
    throw error;
  }
}

function centerOnUser(options = {}) {
  if (!currentLocation) return;
  const target = focusTargetForCurrentMode(currentLocation);
  const zoom = options.zoom ?? map.getZoom();
  withProgrammaticMapMove(() => {
    if (options.animate === false) {
      map.setView(target, zoom, { animate: false });
    } else {
      map.flyTo(target, zoom, { duration: 0.55 });
    }
  });
}

function updateLocateButtonLabel() {
  const modeLabel = currentNavigationMode().label;
  locateButton.innerHTML = `<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 2v3" /><path d="M12 19v3" /><path d="M2 12h3" /><path d="M19 12h3" /><circle cx="12" cy="12" r="7" /><circle cx="12" cy="12" r="2" /></svg>${isFollowingUser ? `Mi ubicacion · ${modeLabel}` : "Mi ubicacion"}`;
}

function disengageFollowMode(messageText) {
  if (!isFollowingUser) return;
  isFollowingUser = false;
  updateLocateButtonLabel();
  addActiveMessage({
    title: "Mapa libre",
    body: messageText || "Moviste el mapa manualmente. Toca Mi ubicacion para volver a centrar.",
  }, { autoHide: true });
}
function formatTrackedDistanceLabel() {
  if (trackedRouteDistanceMeters < 1000) {
    return `${Math.round(trackedRouteDistanceMeters)} m`;
  }
  return `${(trackedRouteDistanceMeters / 1000).toFixed(2)} km`;
}

function updateRouteTrackingUi() {
  if (trackStatusBadge) {
    trackStatusBadge.textContent = isRouteTracking ? "REC" : "OFF";
    trackStatusBadge.style.background = isRouteTracking ? "#d85b45" : "#6c5aa8";
  }

  if (trackRouteButton) {
    trackRouteButton.innerHTML = `<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M3 12h4" /><path d="M17 12h4" /><circle cx="12" cy="12" r="3" /><path d="M12 3v4" /><path d="M12 17v4" /></svg>${isRouteTracking ? "Detener grabacion" : "Registrar camino"}`;
  }

  if (trackSummary) {
    trackSummary.textContent = trackedRoutePoints.length > 1
      ? `Puntos: ${trackedRoutePoints.length} · Distancia: ${formatTrackedDistanceLabel()}`
      : "Sin recorrido grabado.";
  }

  const hasTrack = trackedRoutePoints.length > 1;
  if (saveRouteButton) saveRouteButton.disabled = !hasTrack;
  if (shareRouteButton) shareRouteButton.disabled = !hasTrack;
}

function pushTrackedPoint(current) {
  if (!isRouteTracking) return;
  if (!lastTrackedPoint) {
    trackedRoutePoints.push(current);
    lastTrackedPoint = current;
    trackedRouteLine.setLatLngs(trackedRoutePoints);
    updateRouteTrackingUi();
    return;
  }

  const delta = map.distance(lastTrackedPoint, current);
  if (delta < 8) return;
  trackedRouteDistanceMeters += delta;
  trackedRoutePoints.push(current);
  lastTrackedPoint = current;
  trackedRouteLine.setLatLngs(trackedRoutePoints);
  updateRouteTrackingUi();
}

