baseLayer.on("tileerror", (event) => {
  const tile = event.tile;
  const originalSrc = tile.src;
  window.setTimeout(() => {
    tile.src = `${originalSrc}${originalSrc.includes("?") ? "&" : "?"}retry=${Date.now()}`;
  }, 600);
});

baseLayer.on("load", () => {
  refreshMapSize();
});

